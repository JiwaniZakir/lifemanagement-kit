# ── AI Feature Planner ──
ANTHROPIC_API_KEY=sk-ant-...
# Model: claude-sonnet-4-6 (default), claude-haiku-4-5, claude-opus-4-6
PLANNER_MODEL=claude-sonnet-4-6

# ── GitHub Issue Submission (fine-grained PAT with issues:read+write on lifemanagement-kit) ──
GITHUB_TOKEN=ghp_...

# ── Authentication (NextAuth v5) ──
NEXTAUTH_SECRET=  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (for fork/branch features)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (for sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database (Vercel Postgres) ──
# Only required for deploy/dashboard features. App works without it.
# POSTGRES_URL=postgres://...

# ── Cron Jobs ──
CRON_SECRET=  # openssl rand -base64 32

# ── Stripe (billing) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Analytics (PostHog) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Deployment (optional — only needed if using Hetzner deploy) ──
# These are entered by users in the deploy wizard, not set as env vars.
# HETZNER_TOKEN and CLOUDFLARE_TOKEN are ephemeral and never stored.
