# =============================================================================
# Aegis — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env.
# The bootstrap script auto-generates secrets marked with [auto].
# =============================================================================

# =============================================================================
# REQUIRED — Core platform secrets (bootstrap auto-generates these)
# =============================================================================

ENVIRONMENT=development

# Machine-to-machine auth for OpenClaw -> data-api [auto]
DATA_API_TOKEN=

# AES-256 encryption key for credentials and PII (64 hex chars) [auto]
ENCRYPTION_MASTER_KEY=

# --- Database [auto] ---------------------------------------------------------

POSTGRES_USER=aegis
POSTGRES_PASSWORD=
POSTGRES_DB=aegis

# --- OpenClaw Gateway (required) ---------------------------------------------

ANTHROPIC_API_KEY=                     # Required: Anthropic API key for Claude

# --- OpenClaw Gateway (optional) ---------------------------------------------

OPENCLAW_GATEWAY_TOKEN=                # Gateway admin token [auto]
BRAVE_API_KEY=                         # Enables web_search tool
ADMIN_EMAIL=                           # Used by email-related features

# --- WhatsApp ----------------------------------------------------------------

WHATSAPP_ADMIN_PHONE=                  # Phone with country code (e.g. 15551234567)

# =============================================================================
# OPTIONAL — Integration credentials (enable as needed)
# =============================================================================
# Each integration is independent. Leave blank to disable.
# Credentials for Canvas LMS are stored encrypted via POST /credentials,
# NOT in this file — only the base URL goes here.

# --- Plaid (Banking) ---------------------------------------------------------
# Sign up at https://dashboard.plaid.com/ for client ID and secret

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                      # sandbox | development | production

# --- Schwab (Investments) ----------------------------------------------------
# Register at https://developer.schwab.com/ for API access

SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=                   # OAuth callback (e.g. https://yourdomain.com/callback)

# --- Google (Calendar) -------------------------------------------------------
# Create OAuth 2.0 credentials at https://console.cloud.google.com/

GOOGLE_CLIENT_ID=                      # Format: 123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# --- Microsoft (Outlook Calendar) --------------------------------------------
# Register app at https://portal.azure.com/ > App registrations

AZURE_CLIENT_ID=                       # Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=                       # Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Canvas LMS --------------------------------------------------------------
# Token is stored encrypted via POST /credentials (not in .env)

CANVAS_API_URL=https://canvas.drexel.edu/api/v1  # Your institution's Canvas URL (e.g., https://canvas.yourschool.edu/api/v1)

# --- Blackboard ---------------------------------------------------------------

BLACKBOARD_URL=                        # e.g. https://learn.yourschool.edu
BLACKBOARD_USERNAME=
BLACKBOARD_PASSWORD=

# --- LinkedIn -----------------------------------------------------------------
# Requires approved LinkedIn API app for posting

LINKEDIN_ACCESS_TOKEN=

# --- X / Twitter --------------------------------------------------------------
# Requires X API Basic tier ($100/mo) for read + write

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# --- Garmin -------------------------------------------------------------------
# Uses unofficial garminconnect library — may break with updates

GARMIN_EMAIL=
GARMIN_PASSWORD=

# =============================================================================
# INFRASTRUCTURE — Production & operational settings
# =============================================================================

# --- Cloudflare Tunnel (production only) --------------------------------------

CLOUDFLARE_TUNNEL_TOKEN=

# --- Health Goals -------------------------------------------------------------

DAILY_PROTEIN_TARGET_G=175
DAILY_CALORIE_LIMIT=1900

# --- LLM Budget Guardrails ---------------------------------------------------

LLM_DAILY_BUDGET_USD=5.00
LLM_MONTHLY_BUDGET_USD=50.00
