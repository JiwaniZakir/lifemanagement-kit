# =============================================================================
# Aegis — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env.
# The bootstrap script auto-generates secrets marked with [auto].
# =============================================================================

# --- Required ----------------------------------------------------------------

ENVIRONMENT=development

# Machine-to-machine auth for OpenClaw → data-api [auto]
DATA_API_TOKEN=

# AES-256 encryption key for credentials and PII [auto]
ENCRYPTION_MASTER_KEY=

# --- Database [auto] ---------------------------------------------------------

POSTGRES_USER=aegis
POSTGRES_PASSWORD=
POSTGRES_DB=aegis

# --- OpenClaw Gateway (required) ---------------------------------------------

ANTHROPIC_API_KEY=                     # Required: Anthropic API key for Claude

# --- OpenClaw Gateway (optional) ---------------------------------------------

OPENCLAW_GATEWAY_TOKEN=                # Gateway admin token [auto]
BRAVE_API_KEY=                         # Enables web_search tool
ADMIN_EMAIL=                           # Used by email-related features

# --- WhatsApp ----------------------------------------------------------------

WHATSAPP_ADMIN_PHONE=                  # Phone with country code (e.g. 15551234567)

# --- Plaid (Banking) ---------------------------------------------------------

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                      # sandbox | development | production

# --- Schwab (Investments) ----------------------------------------------------

SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=

# --- Google (Calendar) -------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft (Outlook Calendar) --------------------------------------------

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# --- Canvas LMS --------------------------------------------------------------
# Token is stored encrypted via POST /credentials (not in .env)

CANVAS_API_URL=https://canvas.drexel.edu/api/v1

# --- Blackboard ---------------------------------------------------------------

BLACKBOARD_URL=
BLACKBOARD_USERNAME=
BLACKBOARD_PASSWORD=

# --- LinkedIn -----------------------------------------------------------------

LINKEDIN_ACCESS_TOKEN=

# --- X / Twitter --------------------------------------------------------------

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# --- Garmin -------------------------------------------------------------------

GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Cloudflare Tunnel (production only) --------------------------------------

CLOUDFLARE_TUNNEL_TOKEN=

# --- Health Goals -------------------------------------------------------------

DAILY_PROTEIN_TARGET_G=175
DAILY_CALORIE_LIMIT=1900

# --- LLM Budget Guardrails ---------------------------------------------------

LLM_DAILY_BUDGET_USD=5.00
LLM_MONTHLY_BUDGET_USD=50.00
